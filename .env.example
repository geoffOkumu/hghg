# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hghg_newsletter?schema=public"

# Admin Credentials (used for seeding)
ADMIN_EMAIL="admin@hghg.church"
ADMIN_PASSWORD="your-secure-password-here"

# JWT Secret (generate a random string)
JWT_SECRET="your-jwt-secret-here-change-this"

# Resend API Key (https://resend.com)
RESEND_API_KEY="re_your_api_key_here"

# Email sender address (must be verified in Resend)
FROM_EMAIL="newsletter@hghg.church"

# Public site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
